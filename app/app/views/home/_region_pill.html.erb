<div id="region_pill" class="fixed bottom-3 right-3 z-20 pointer-events-auto">
  <% region = local_assigns[:region] || RegionContext.current(regions_dir: defined?(@regions_dir) && @regions_dir || Rails.root.join("..", "regions")) %>
  <% unless region.empty? %>
    <div class="bg-base-100/95 backdrop-blur border border-base-300 rounded-box shadow-md px-3 py-1.5 flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
      <span class="font-display font-semibold text-sm tracking-tight"><%= region.label %></span>
      <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-base-content/50">tap settings</span>
    </div>
  <% end %>
</div>
