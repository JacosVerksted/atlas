#!/bin/bash -e

# Prepare all configured databases (primary, queue, cache, cable) whenever we
# boot the Rails server. db:prepare is idempotent — creates DBs if missing,
# loads schema.rb on fresh installs, runs pending migrations on upgrades, and
# is a no-op when the schema is already current.
case "${*}" in
  *"rails server"*|*"rails s"*|*"thrust"*)
    ./bin/rails db:prepare
    ;;
esac

exec "${@}"
