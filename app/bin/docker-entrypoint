#!/bin/bash -e

# On every Rails server boot:
#   1. db:prepare  — create each DB if missing (primary/queue/cache/cable),
#                    load schema.rb on first run, run pending migrations on
#                    upgrades. No-op when the schema is already current.
#   2. db:seed     — run db/seeds.rb. Seeds MUST be idempotent
#                    (use find_or_create_by! / upsert! patterns).
case "${*}" in
  *"rails server"*|*"rails s"*|*"thrust"*)
    ./bin/rails db:prepare
    ./bin/rails db:seed
    ;;
esac

exec "${@}"
