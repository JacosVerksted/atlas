# Atlas .env — copy this file to .env and edit as needed.
#
# SECRET_KEY_BASE: auto-generated on first boot and persisted to
#   data/app/.secret_key_base (under the bind-mounted volume). Set this
#   yourself only if you want to share a key across hosts.
#
# SECRET_KEY_BASE=replace-with-output-of-openssl-rand-hex-64

# PostgreSQL (used by default in production)
POSTGRES_USER=atlas
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=atlas
# DATABASE_URL is auto-constructed from the above in compose.yml.
# Override here only if connecting to an external database:
# DATABASE_URL=postgresql://atlas:password@db-host:5432/atlas

# Region selection (ISO-2 country code; see Geofabrik for valid extracts)
# Switch regions easily: make region NAME=norway  (or germany, nordic, etc.)
# List presets:          make region-list
# Create your own:       make region-create-country NAME=france CODE=fr GEOFABRIK=europe/france
COUNTRY_CODE=no
PBF_URL=https://download.geofabrik.de/europe/norway-latest.osm.pbf
PBF_NAME=norway-latest.osm.pbf
OVERPASS_DIFF_URL=https://download.geofabrik.de/europe/norway-updates/

# Map center defaults (Norway)
DEFAULT_LAT=65.0
DEFAULT_LON=15.0
DEFAULT_ZOOM=5

# NOTE: pelias/whosonfirst:latest currently IGNORES this — it always pulls the global
# WOF bundle (~68 GB transient, ~3-6 GB final store). Kept here for forward-compat in case
# the upstream image restores country filtering.
WHOSONFIRST_COUNTRY_CODE=no

# Set to False to skip SRTM download in Valhalla (saves ~3–30 GB per region).
BUILD_ELEVATION=True

# Docker socket access for atlas-control. Defaults to the local socket.
# Point at a socket-proxy for restricted access:
# DOCKER_HOST=tcp://socket-proxy:2375
# DOCKER_SOCK=/var/run/docker.sock
