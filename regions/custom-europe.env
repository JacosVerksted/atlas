# Custom Europe: Norway + Sweden + Denmark + Germany + Netherlands
# ~20 GB merged PBF. Run `make merge-pbf` after `make region NAME=custom-europe`.

REGION_NAME=custom-europe
REGION_LABEL="Custom Europe (NO + SE + DK + DE + NL)"
COUNTRY_CODE=no
REGIONS="no,se,dk,de,nl"
PBF_URLS="https://download.geofabrik.de/europe/norway-latest.osm.pbf https://download.geofabrik.de/europe/sweden-latest.osm.pbf https://download.geofabrik.de/europe/denmark-latest.osm.pbf https://download.geofabrik.de/europe/germany-latest.osm.pbf https://download.geofabrik.de/europe/netherlands-latest.osm.pbf"
PBF_URL=local://data/osm/custom-europe-merged.osm.pbf
PBF_NAME=custom-europe-merged.osm.pbf
OVERPASS_DIFF_URL=
DEFAULT_LAT=55.0
DEFAULT_LON=10.0
DEFAULT_ZOOM=5
TILES_BBOX=3.0,47.0,31.5,71.3
